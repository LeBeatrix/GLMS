@model GLMS.Web.Models.ServiceRequest

@{
    ViewData["Title"] = "Create Service Request";
}

<h1>Create Service Request</h1>

<h4>Service Request</h4>
<hr />

<div class="row">
    <div class="col-md-5">
        <form asp-action="Create" method="post">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group mb-3">
                <label asp-for="ContractId" class="control-label">Contract</label>
                <select asp-for="ContractId"
                        class="form-control"
                        asp-items="ViewBag.ContractId">
                    <option value="">-- Select Contract --</option>
                </select>
                <span asp-validation-for="ContractId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Description" class="control-label">Request Description</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CostUSD" class="control-label">Cost in USD</label>
                <input asp-for="CostUSD"
                       class="form-control"
                       type="number"
                       step="0.01"
                       min="0.01"
                       placeholder="Example: 100" />
                <span asp-validation-for="CostUSD" class="text-danger"></span>
            </div>

            <input asp-for="CostZAR" type="hidden" value="0" />

            <div class="alert alert-info">
                The ZAR amount will be calculated automatically after you click
                <strong>Create Service Request</strong>.
            </div>

            <div class="form-group mb-3">
                <label asp-for="Status" class="control-label">Request Status</label>
                <select asp-for="Status" class="form-control">
                    <option value="Pending">Pending</option>
                    <option value="Approved">Approved</option>
                    <option value="Rejected">Rejected</option>
                    <option value="Completed">Completed</option>
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Create Service Request" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}